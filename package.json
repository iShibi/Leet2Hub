{
	"name": "leet2hub",
	"version": "0.1.0",
	"private": true,
	"description": "A browser extension that uploads LeetCode submissions to GitHub.",
	"author": {
		"name": "Shubham Parihar",
		"email": "shubhamparihar391@gmail.com",
		"url": "https://github.com/iShibi"
	},
	"scripts": {
		"prepare": "lefthook install",
		"build:firefox": "tsc -b && vite build --config vite.config.firefox.ts",
		"build:chrome": "tsc -b && vite build --config vite.config.chrome.ts",
		"build:all": "npm run build:firefox && npm run build:chrome",
		"lint:check": "biome lint",
		"lint:write": "biome lint --write",
		"format:check": "biome format",
		"format:write": "biome format --write"
	},
	"dependencies": {
		"@preact/signals": "^2.8.1",
		"preact": "^10.28.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@preact/preset-vite": "^2.10.3",
		"@tailwindcss/vite": "^4.2.1",
		"@types/chrome": "^0.1.37",
		"@types/node": "^24.10.1",
		"lefthook": "^2.1.1",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"type": "module",
	"license": "MIT"
}
